---
import { NAV, WWW, GITHUB_ORG } from '../data/site.js';
---
<header class="site-header">
  <div class="wrap">
    <a class="brand" href={WWW} aria-label="dotcommoners home">
      <span class="dot" aria-hidden="true"></span>
      dotcommoners
    </a>
    <nav class="nav primary-nav" id="primary-nav" aria-label="Primary">
      {NAV.map((item) => (
        <a href={item.href} class={item.label === 'Docs' ? 'hide-sm' : ''}>{item.label}</a>
      ))}
    </nav>
    <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="primary-nav">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M4 7h16M4 12h16M4 17h16" />
      </svg>
    </button>
  </div>
</header>
<script>
  const btn = document.getElementById('nav-toggle');
  const nav = document.getElementById('primary-nav');
  if (btn && nav) {
    btn.addEventListener('click', () => {
      const open = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    nav.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        nav.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      })
    );
  }
</script>
