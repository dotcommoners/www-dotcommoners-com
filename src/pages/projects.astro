---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { PROJECTS, GITHUB_ORG, DOCS, WWW, orgSchema, websiteSchema, breadcrumbSchema } from '../data/site.js';

const title = 'Projects — dotcommoners open-source infrastructure';
const description =
  'The open-source projects from dotcommoners: Machineuse (browser automation, Python) and RevenProx (a Zig SSE proxy). All MIT-licensed and self-hostable.';
const keywords = [
  'dotcommoners projects', 'machineuse', 'revenprox', 'browser automation', 'SSE proxy',
  'open source', 'self-hosted', 'Zig', 'Python', 'distributed systems',
];

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Projects', href: '/projects' },
];

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'dotcommoners projects',
  url: `${WWW}/projects`,
  isPartOf: { '@type': 'WebSite', name: 'dotcommoners', url: WWW },
  mainEntity: {
    '@type': 'ItemList',
    name: 'dotcommoners open-source projects',
    itemListElement: PROJECTS.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'SoftwareSourceCode',
        name: p.name,
        abstract: p.summary,
        programmingLanguage: p.lang,
        codeRepository: p.repo,
        license: 'https://opensource.org/licenses/MIT',
        url: p.site,
      },
    })),
  },
};
---
<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  path="projects"
  jsonLd={[orgSchema, websiteSchema, breadcrumbSchema(crumbs), collectionSchema]}
>
  <section class="hero">
    <div class="wrap">
      <Breadcrumbs items={crumbs} />
      <span class="eyebrow">Projects</span>
      <h1>Open-source infrastructure you can run yourself</h1>
      <p class="lede">
        Every dotcommoners project is MIT-licensed, documented, and built to be self-hosted on
        your own hardware. Below is the full portfolio, what each one does, and where to read the
        source.
      </p>
      <div class="answer" style="max-width:44rem; margin-top:2.2rem;">
        <span class="lbl">Summary</span>
        <p>
          dotcommoners currently publishes {PROJECTS.length} open-source projects:
          Machineuse (distributed browser automation, Python) and RevenProx (a high-performance
          SSE proxy, Zig). Both are brokerless, horizontally scalable, and self-hostable.
        </p>
      </div>
    </div>
  </section>

  <hr class="hr" />

  <section>
    <div class="wrap">
      <div class="grid" style="gap:1.6rem;">
        {PROJECTS.map((p) => (
          <article class="card proj-row">
            <span class="meta-line">{p.category} · {p.lang} · MIT</span>
            <h2><a href={p.site}>{p.name}</a></h2>
            {p.long.map((para) => <p>{para}</p>)}
            <div>
              {p.topics.map((t) => <span class="pill">{t}</span>)}
            </div>
            <div class="links" style="display:flex; gap:1.2rem; padding-top:.6rem; font-size:.92rem;">
              <a href={p.site}>Overview →</a>
              <a href={p.docs}>Documentation</a>
              <a href={p.repo}>GitHub repository</a>
            </div>
          </article>
        ))}
      </div>

      <div class="answer" style="margin-top:2.6rem; max-width:46rem;">
        <span class="lbl">More projects</span>
        <p>
          dotcommoners is actively building additional systems software in Rust, Zig, and Python.
          New public projects appear on the <a href={GITHUB_ORG}>GitHub organization</a> as they
          are released — watch the org or read the <a href={DOCS}>documentation</a> to follow along.
        </p>
      </div>
    </div>
  </section>

  <section style="background:var(--bg-soft); border-top:1px solid var(--border);">
    <div class="wrap" style="text-align:center;">
      <h2>Run these on your own hardware</h2>
      <p style="max-width:36rem; margin:0 auto 2rem;">
        Read the docs, clone a repo, and self-host. Questions or ideas? Get in touch.
      </p>
      <div style="display:flex; gap:.9rem; justify-content:center; flex-wrap:wrap;">
        <a class="btn btn-primary" href={DOCS}>Read the docs</a>
        <a class="btn btn-ghost" href="/contact">Contact us</a>
      </div>
    </div>
  </section>
</BaseLayout>
