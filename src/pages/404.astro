---
import BaseLayout from '../layouts/BaseLayout.astro';
import { GITHUB_ORG, WWW } from '../data/site.js';
---
<BaseLayout title="Page not found — dotcommoners" description="The page you were looking for does not exist." path="404">
  <section class="hero" style="text-align:center;">
    <div class="wrap">
      <span class="eyebrow">404</span>
      <h1>Nothing here</h1>
      <p class="lede" style="margin:0 auto 2rem;">That page doesn't exist — but the source and the docs do.</p>
      <div style="display:flex; gap:.9rem; justify-content:center; flex-wrap:wrap;">
        <a class="btn btn-primary" href={WWW}>Back home</a>
        <a class="btn btn-ghost" href={GITHUB_ORG}>GitHub</a>
      </div>
    </div>
  </section>
</BaseLayout>
